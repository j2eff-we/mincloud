# mincloud dev environment — well-known fake credentials, safe to commit.
# Usage: source .env
export AWS_ACCESS_KEY_ID=MINCLOUDTESTKEY0000A
export AWS_SECRET_ACCESS_KEY=mincloud-test-secret-not-real
export AWS_DEFAULT_REGION=ap-northeast-2

# All services on one port — requests are routed by SigV4 credential scope.
export AWS_ENDPOINT_URL=http://localhost:9900
