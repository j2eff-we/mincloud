# mincloud dev environment — well-known fake credentials, safe to commit.
# Usage: source .env
export AWS_ACCESS_KEY_ID=MINCLOUDTESTKEY0000A
export AWS_SECRET_ACCESS_KEY=mincloud-test-secret-not-real
export AWS_DEFAULT_REGION=ap-northeast-2

# aws CLI v2 reads these per-service endpoints — no --endpoint-url needed.
export AWS_ENDPOINT_URL_STS=http://localhost:9900
export AWS_ENDPOINT_URL_IAM=http://localhost:9910
export AWS_ENDPOINT_URL_EC2=http://localhost:9920
